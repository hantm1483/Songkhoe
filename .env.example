# GlucoCare - Sổ Tay Tiểu Đường
# Environment Variables Template

# ===========================================
# SUPABASE (Required for all environments)
# ===========================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ===========================================
# CLAUDE API (Edge Functions - Supabase)
# ===========================================
# IMPORTANT: ANTHROPIC_API_KEY must be set in Supabase Dashboard
# NOT in Vercel - Supabase Edge Functions cannot access Vercel env vars
# Go to: Supabase Dashboard > Project Settings > Edge Functions > Secrets
ANTHROPIC_API_KEY=sk-ant-xxxxx

# ===========================================
# APP CONFIGURATION
# ===========================================
NEXT_PUBLIC_APP_URL=https://your-domain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ===========================================
# NOTES
# ===========================================
# 1. Copy this file to .env.local for local development
# 2. For production:
#    - Set NEXT_PUBLIC_* variables in Vercel dashboard
#    - Set ANTHROPIC_API_KEY in Supabase dashboard (NOT Vercel)
# 3. Never commit .env.local or .env.production to git